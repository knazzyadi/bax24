  @@index([assetId])
  @@index([status])
  @@index([workOrderId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([roomId])
  @@index([buildingId])
  @@index([companyId, buildingId, deletedAt])
  @@index([companyId, status, createdAt])
  @@index([assetId, createdAt])
