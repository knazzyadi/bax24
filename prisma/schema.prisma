model MaintenanceReport {
  id                     String            @id @default(cuid()) @map("id")
  code                   String            @unique @default(cuid()) @map("code")
  title                  String            @map("title")
  description            String?           @map("description")
  assetId                String?           @map("asset_id")
  reporterName           String            @map("reporter_name")
  reporterEmail          String            @map("reporter_email")
  phone                  String?           @map("phone")
  type                   ReportType        @default(MAINTENANCE) @map("type")
  status                 ReportStatusEnum  @default(PENDING) @map("status")
  workOrderId            String?           @map("work_order_id")
  rejectionReason        String?           @map("rejection_reason")
  severity               IncidentSeverity? @map("severity")
  reportedTo             String?           @map("reported_to")
  investigationNotes     String?           @map("investigation_notes")
  investigatedById       String?           @map("investigated_by_id")
  convertedToWorkOrderId String?           @map("converted_to_work_order_id")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  deletedAt              DateTime?         @map("deleted_at")
  roomId                 String?           @map("room_id")
  companyId              String?           @map("company_id")
  buildingId             String            @map("building_id")
  asset                  Asset?            @relation(fields: [assetId], references: [id])
  building               Building          @relation(fields: [buildingId], references: [id])
  company                Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  convertedToWorkOrder   WorkOrder?        @relation("ConvertedToWorkOrder", fields: [convertedToWorkOrderId], references: [id])
  investigatedBy         User?             @relation("InvestigatedBy", fields: [investigatedById], references: [id])
  room                   Room?             @relation(fields: [roomId], references: [id])
  workOrder              WorkOrder?        @relation("WorkOrderReports", fields: [workOrderId], references: [id])
