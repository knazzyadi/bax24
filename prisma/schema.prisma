generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                    String    @id @default(cuid())
  name                  String    @unique
  nameEn                String?
  address               String?
  phone                 String?
  email                 String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users               User[]
  branches            Branch[]
  buildings           Building[]
  assetTypes          AssetType[]
  assetStatuses       AssetStatus[]
  assets              Asset[]
  inventoryItems      InventoryItem[]
  contracts           Contract[]
  workOrders          WorkOrder[]
  workOrderPriorities WorkOrderPriority[]
  workOrderStatuses   WorkOrderStatus[]
  tickets             Ticket[]
  maintenanceSchedules MaintenanceSchedule[]

  @@map("companies")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  status            Boolean   @default(true)
  companyId         String?
  company           Company?  @relation(fields: [companyId], references: [id])
  branchId          String?
  roleId            String?
  role              Role?     @relation(fields: [roleId], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  invitationToken   String?   @unique
  invitationExpires DateTime?
  firstLogin        Boolean   @default(true)

  userBranches UserBranch[] // ← هذا السطر مهم جداً

  @@map("users")
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique // SUPER_ADMIN, ADMIN, BRANCH_MANAGER, TECH
  label     String? // وصف للعرض
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[] // الآن الحقل المقابل موجود في User (role)

  @@map("roles")
}

model UserBranch {
  userId     String
  branchId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, branchId])
  @@map("user_branches")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  code      String   @unique
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBranches UserBranch[] // ← أضف هذا السطر
  buildings    Building[]
  contracts    Contract[]
  workOrders   WorkOrder[]
  tickets      Ticket[]
  maintenanceSchedules MaintenanceSchedule[]

  @@map("branches")
}

model Building {
  id        String    @id @default(cuid())
  name      String
  nameEn    String?
  code      String    @unique
  order     Int       @default(0)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  floors Floor[] // علاقة عكسية اختيارية
  rooms  Room[]
  assets Asset[]
  maintenanceSchedules MaintenanceSchedule[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  code       String
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms      Room[]
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([buildingId, code])
  @@map("floors")
}

model Room {
  id         String    @id @default(cuid())
  name       String
  nameEn     String?
  code       String
  order      Int       @default(0)
  floorId    String
  buildingId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  floor    Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  // TODO: أضف هذه العلاقات عندما تنشئ النماذج التالية:
  assets         Asset[]
  inventoryItems InventoryItem[]
  tickets        Ticket[]
  // workOrders         WorkOrder[]
  workOrders     WorkOrder[]

  @@unique([floorId, code])
  @@map("rooms")
}

model AssetType {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  code        String?  @unique
  description String?
  order       Int      @default(0)
  isDefault   Boolean  @default(false)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets     Asset[] // علّق هذا السطر مؤقتاً إلى حين إنشاء نموذج Asset
  workOrders WorkOrder[]
  maintenanceSchedules MaintenanceSchedule[]

  @@unique([name, companyId])
  @@map("asset_types")
}

model AssetStatus {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  code        String?  @unique
  description String?
  color       String?  @default("#64748b")
  order       Int      @default(0)
  isDefault   Boolean  @default(false)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[] // علاقة مستقبلية (عند إضافة نموذج Asset)

  @@unique([name, companyId])
  @@map("asset_statuses")
}

model Asset {
  id           String    @id @default(cuid())
  code         String    @unique @default(cuid())
  name         String
  nameEn       String?
  typeId       String?
  statusId     String?
  roomId       String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  notes        String?
  qrCode       String?   @unique
  companyId    String
  buildingId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  // علاقات
  type       AssetType?   @relation(fields: [typeId], references: [id])
  status     AssetStatus? @relation(fields: [statusId], references: [id])
  room       Room?        @relation(fields: [roomId], references: [id])
  building   Building     @relation(fields: [buildingId], references: [id])
  company    Company      @relation(fields: [companyId], references: [id])
  tickets    Ticket[]
  workOrderAssets WorkOrderAsset[]
  scheduleAssets ScheduleAsset[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([typeId])
  @@index([statusId])
  @@index([roomId])
  @@index([buildingId])
  @@index([deletedAt])
  @@map("assets")
}

model InventoryItem {
  id          String    @id @default(cuid())
  sku         String?   @unique
  name        String
  nameEn      String?
  quantity    Int       @default(0)
  minQuantity Int       @default(0)
  unit        String?   @default("قطعة")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  roomId    String // هذا هو الحقل الذي يربط بالغرفة
  room      Room    @relation(fields: [roomId], references: [id])
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([roomId])
  @@index([sku])
}

model Contract {
  id                 String         @id @default(cuid())
  code               String?        @unique
  title              String
  supplier           String
  value              Float
  startDate          DateTime
  endDate            DateTime
  description        String?
  status             ContractStatus @default(PENDING_REVIEW)
  cancellationReason String?
  notes              String?
  attachments        Json? // تخزين مصفوفة المرفقات [{ name, url, type, size }]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  // العلاقات
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String? // اختياري: ربط العقد بفرع معين لعزله حسب الفرع
  branch    Branch? @relation(fields: [branchId], references: [id])
  createdBy String? // معرف المستخدم الذي أنشأ العقد (احتياطي)

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

enum ContractStatus {
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  CANCELLED
}

// ========== نموذج WorkOrder ==========
model WorkOrder {
  id          String   @id @default(cuid())
  code        String?  @unique
  title       String
  description String?
  type        WorkOrderType @default(MAINTENANCE)
  priorityId  String?
  priority    WorkOrderPriority? @relation(fields: [priorityId], references: [id])
  statusId    String?
  status      WorkOrderStatus? @relation(fields: [statusId], references: [id])
  roomId      String?
  room        Room?    @relation(fields: [roomId], references: [id])
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  createdBy   String?
  assetType   AssetType? @relation(fields: [assetTypeId], references: [id])
  assetTypeId String?
  
  // العلاقة مع Ticket (المفتاح الأجنبي هنا)
  ticketId    String?   @unique
  ticket      Ticket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  
  // بقية العلاقات الأخرى...
  workOrderAssets WorkOrderAsset[]
  
  @@index([companyId])
  @@index([branchId])
  @@index([roomId])
  @@index([statusId])
}

// ========== نموذج جديد لربط أمر العمل بالأصول ==========
model WorkOrderAsset {
  workOrderId  String
  assetId      String
  completedAt  DateTime?   // تاريخ إتمام الصيانة لهذا الأصل بالذات
  notes        String?     // ملاحظات خاصة
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([workOrderId, assetId])
}

// ========== إضافة نوع جديد لـ WorkOrderType (اختياري) ==========
enum WorkOrderType {
  MAINTENANCE
  CORRECTIVE
  EMERGENCY
  BULK_PREVENTIVE   // للصيانة الجماعية المجدولة
}

// ========== نموذج جدول الصيانة الدورية ==========
model MaintenanceSchedule {
  id           String   @id @default(cuid())
  name         String
  frequency    String
  leadDays     Int      @default(30)
  startDate    DateTime? // تاريخ البداية للصيانة الأولى (اختياري)
  branchId     String?
  buildingId   String?
  assetTypeId  String?
  companyId    String
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastRunAt    DateTime?

  // العلاقات
  company      Company     @relation(fields: [companyId], references: [id])
  branch       Branch?     @relation(fields: [branchId], references: [id])
  building     Building?   @relation(fields: [buildingId], references: [id])
  assetType    AssetType?  @relation(fields: [assetTypeId], references: [id])
  scheduleAssets ScheduleAsset[]
}

// ========== جدول وسيط لربط جدول الصيانة بأصول محددة ==========
model ScheduleAsset {
  scheduleId String
  assetId    String
  schedule   MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  asset      Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([scheduleId, assetId])
}

model WorkOrderPriority {
  id        String  @id @default(cuid())
  name      String
  nameEn    String?
  code      String? @unique
  order     Int     @default(0)
  isDefault Boolean @default(false)
  color     String? @default("#64748b")   // ✅ Add this line
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  workOrders WorkOrder[]

  @@unique([companyId, name])
}

model WorkOrderStatus {
  id        String  @id @default(cuid())
  name      String
  nameEn    String?
  color     String? // لون الحالة (مثل #00ba7c)
  order     Int     @default(0)
  isDefault Boolean @default(false)
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  workOrders WorkOrder[]

  @@unique([companyId, name])
}

// ========== نموذج Ticket ==========
model Ticket {
  id            String    @id @default(cuid())
  code          String?   @unique
  type          String
  title         String
  description   String?
  reporterName  String
  reporterEmail String
  phone         String?
  status        String    @default("PENDING")
  rejectionReason String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  companyId     String
  roomId        String?
  branchId      String?
  assetId       String?
  createdBy     String?
  
  // العلاقة مع WorkOrder (بدون حقل تخزين)
  workOrder     WorkOrder?  // علاقة واحد لواحد (virtual)
  
  // بقية العلاقات الأخرى...
  asset         Asset?    @relation(fields: [assetId], references: [id])
  room          Room?     @relation(fields: [roomId], references: [id])
  company       Company   @relation(fields: [companyId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])
  ticketImages  TicketImage[]
  
  @@index([companyId])
  @@index([branchId])
  @@index([assetId])
  @@index([roomId])
  @@index([status])
}

model TicketImage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  url       String
  createdAt DateTime @default(now())
}
