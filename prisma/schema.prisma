generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                    String                @id @default(cuid())
  name                  String                @unique
  nameEn                String?
  address               String?
  phone                 String?
  email                 String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  contracts             Contract[]
  inventoryItems        InventoryItem[]
  maintenanceSchedules  MaintenanceSchedule[]
  tickets               Ticket[]
  workOrders            WorkOrder[]
  workOrderPriorities   WorkOrderPriority[]
  workOrderStatuses     WorkOrderStatus[]
  assetStatuses         AssetStatus[]
  assetTypes            AssetType[]
  assets                Asset[]
  branches              Branch[]
  buildings             Building[]
  users                 User[]

  @@map("companies")
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  name              String?
  password          String?
  status            Boolean      @default(true)
  companyId         String?
  branchId          String?
  roleId            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  invitationToken   String?      @unique
  invitationExpires DateTime?
  firstLogin        Boolean      @default(true)
  userBranches      UserBranch[]
  company           Company?     @relation(fields: [companyId], references: [id])
  role              Role?        @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("roles")
}

model UserBranch {
  userId     String
  branchId   String
  assignedAt DateTime @default(now())
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model Branch {
  id                   String                @id @default(cuid())
  name                 String
  code                 String                @unique
  companyId            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  nameEn               String?
  contracts            Contract[]
  maintenanceSchedules MaintenanceSchedule[]
  tickets              Ticket[]
  workOrders           WorkOrder[]
  company              Company               @relation(fields: [companyId], references: [id])
  buildings            Building[]
  userBranches         UserBranch[]

  @@map("branches")
}

model Building {
  id                   String                @id @default(cuid())
  name                 String
  nameEn               String?
  code                 String                @unique
  order                Int                   @default(0)
  branchId             String?
  companyId            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  maintenanceSchedules MaintenanceSchedule[]
  assets               Asset[]
  branch               Branch?               @relation(fields: [branchId], references: [id])
  company              Company               @relation(fields: [companyId], references: [id])
  floors               Floor[]
  rooms                Room[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(cuid())
  name       String
  nameEn     String?
  code       String
  buildingId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  rooms      Room[]

  @@unique([buildingId, code])
  @@map("floors")
}

model Room {
  id             String          @id @default(cuid())
  name           String
  nameEn         String?
  code           String
  order          Int             @default(0)
  floorId        String
  buildingId     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  inventoryItems InventoryItem[]
  tickets        Ticket[]
  workOrders     WorkOrder[]
  assets         Asset[]
  building       Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor          Floor           @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@unique([floorId, code])
  @@map("rooms")
}

model AssetType {
  id                   String                @id @default(cuid())
  name                 String
  nameEn               String?
  code                 String?               @unique
  description          String?
  order                Int                   @default(0)
  isDefault            Boolean               @default(false)
  companyId            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  maintenanceSchedules MaintenanceSchedule[]
  workOrders           WorkOrder[]
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets               Asset[]

  @@unique([name, companyId])
  @@map("asset_types")
}

model AssetStatus {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  code        String?  @unique
  description String?
  color       String?  @default("#64748b")
  order       Int      @default(0)
  isDefault   Boolean  @default(false)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets      Asset[]

  @@unique([name, companyId])
  @@map("asset_statuses")
}

model Asset {
  id              String           @id @default(cuid())
  code            String           @unique @default(cuid())
  name            String
  nameEn          String?
  typeId          String?
  statusId        String?
  roomId          String?
  purchaseDate    DateTime?
  warrantyEnd     DateTime?
  notes           String?
  qrCode          String?          @unique
  companyId       String
  buildingId      String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  scheduleAssets  ScheduleAsset[]
  tickets         Ticket[]
  workOrderAssets WorkOrderAsset[]
  building        Building         @relation(fields: [buildingId], references: [id])
  company         Company          @relation(fields: [companyId], references: [id])
  room            Room?            @relation(fields: [roomId], references: [id])
  status          AssetStatus?     @relation(fields: [statusId], references: [id])
  type            AssetType?       @relation(fields: [typeId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([typeId])
  @@index([statusId])
  @@index([roomId])
  @@index([buildingId])
  @@index([deletedAt])
  @@map("assets")
}

model InventoryItem {
  id          String    @id @default(cuid())
  sku         String?   @unique
  name        String
  nameEn      String?
  quantity    Int       @default(0)
  minQuantity Int       @default(0)
  unit        String?   @default("قطعة")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  roomId      String
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  room        Room      @relation(fields: [roomId], references: [id])

  @@index([companyId])
  @@index([roomId])
  @@index([sku])
}

model Contract {
  id                 String         @id @default(cuid())
  code               String?        @unique
  title              String
  supplier           String
  value              Float
  startDate          DateTime
  endDate            DateTime
  description        String?
  status             ContractStatus @default(PENDING_REVIEW)
  cancellationReason String?
  notes              String?
  attachments        Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  companyId          String
  branchId           String?
  createdBy          String?
  branch             Branch?        @relation(fields: [branchId], references: [id])
  company            Company        @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model WorkOrder {
  id              String             @id @default(cuid())
  code            String?            @unique
  title           String
  description     String?
  type            WorkOrderType      @default(MAINTENANCE)
  priorityId      String?
  statusId        String?
  roomId          String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  companyId       String
  branchId        String?
  createdBy       String?
  assetTypeId     String?
  ticketId        String?            @unique
  assetType       AssetType?         @relation(fields: [assetTypeId], references: [id])
  branch          Branch?            @relation(fields: [branchId], references: [id])
  company         Company            @relation(fields: [companyId], references: [id])
  priority        WorkOrderPriority? @relation(fields: [priorityId], references: [id])
  room            Room?              @relation(fields: [roomId], references: [id])
  status          WorkOrderStatus?   @relation(fields: [statusId], references: [id])
  ticket          Ticket?            @relation(fields: [ticketId], references: [id])
  workOrderAssets WorkOrderAsset[]

  @@index([companyId])
  @@index([branchId])
  @@index([roomId])
  @@index([statusId])
}

model WorkOrderAsset {
  workOrderId String
  assetId     String
  completedAt DateTime?
  notes       String?
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@id([workOrderId, assetId])
}

model MaintenanceSchedule {
  id             String          @id @default(cuid())
  name           String
  frequency      String
  leadDays       Int             @default(30)
  branchId       String?
  buildingId     String?
  assetTypeId    String?
  companyId      String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastRunAt      DateTime?
  notes          String?
  startDate      DateTime?
  assetType      AssetType?      @relation(fields: [assetTypeId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  building       Building?       @relation(fields: [buildingId], references: [id])
  company        Company         @relation(fields: [companyId], references: [id])
  scheduleAssets ScheduleAsset[]
}

model ScheduleAsset {
  scheduleId String
  assetId    String
  asset      Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  schedule   MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@id([scheduleId, assetId])
}

model WorkOrderPriority {
  id         String      @id @default(cuid())
  name       String
  nameEn     String?
  code       String?     @unique
  order      Int         @default(0)
  isDefault  Boolean     @default(false)
  companyId  String
  color      String?     @default("#64748b")
  workOrders WorkOrder[]
  company    Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
}

model WorkOrderStatus {
  id         String      @id @default(cuid())
  name       String
  nameEn     String?
  color      String?
  order      Int         @default(0)
  isDefault  Boolean     @default(false)
  companyId  String
  workOrders WorkOrder[]
  company    Company     @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
}

model Ticket {
  id              String        @id @default(cuid())
  code            String?       @unique
  title           String
  description     String?
  assetId         String?
  roomId          String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  companyId       String
  branchId        String?
  createdBy       String?
  type            String
  phone           String?
  reporterEmail   String
  reporterName    String
  status          String        @default("PENDING")
  rejectionReason String?
  asset           Asset?        @relation(fields: [assetId], references: [id])
  branch          Branch?       @relation(fields: [branchId], references: [id])
  company         Company       @relation(fields: [companyId], references: [id])
  room            Room?         @relation(fields: [roomId], references: [id])
  ticketImages    TicketImage[]
  workOrder       WorkOrder?

  @@index([companyId])
  @@index([branchId])
  @@index([assetId])
  @@index([roomId])
  @@index([status])
}

model TicketImage {
  id        String   @id @default(cuid())
  url       String
  ticketId  String
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
}

enum ContractStatus {
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  CANCELLED
}

enum WorkOrderType {
  MAINTENANCE
  CORRECTIVE
  EMERGENCY
  BULK_PREVENTIVE
}
