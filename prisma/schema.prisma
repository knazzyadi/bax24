model WorkOrder {
  id                 String              @id @default(cuid()) @map("id")
  code               String              @unique @default(cuid()) @map("code")
  title              String              @map("title")
  description        String?             @map("description")
  priorityId         String?             @map("priority_id")
  statusId           String?             @map("status_id")
  assetId            String?             @map("asset_id")
  assignedToId       String?             @map("assigned_to_id")
  createdById        String              @map("created_by_id")
  scheduledAt        DateTime?           @map("scheduled_at")
  completedAt        DateTime?           @map("completed_at")
  companyId          String              @map("company_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  notes              String?             @map("notes")
  type               String              @default("MAINTENANCE") @map("type")
  deletedAt          DateTime?           @map("deleted_at")
  roomId             String?             @map("room_id")
  buildingId         String              @map("building_id")
  incidentReports    MaintenanceReport[] @relation("ConvertedToWorkOrder")
  maintenanceReports MaintenanceReport[] @relation("WorkOrderReports")
  MaintenanceTask    MaintenanceTask[]
  stockMovements     StockMovement[]
  items              WorkOrderItem[]
  asset              Asset?              @relation(fields: [assetId], references: [id])
  assignedTo         User?               @relation("AssignedWorkOrders", fields: [assignedToId], references: [id])
  building           Building            @relation(fields: [buildingId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("CreatedWorkOrders", fields: [createdById], references: [id])
  priority           WorkOrderPriority?  @relation(fields: [priorityId], references: [id], onDelete: Restrict)
  room               Room?               @relation(fields: [roomId], references: [id])
  status             WorkOrderStatus?    @relation(fields: [statusId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([statusId])
  @@index([priorityId])
  @@index([assetId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([roomId])
  @@index([buildingId])
  @@index([companyId, buildingId, deletedAt])
  @@index([statusId, priorityId, scheduledAt])
  @@index([assignedToId, statusId])
  @@index([companyId, statusId, assignedToId])
  @@map("work_orders")
}

model WorkOrderItem {
