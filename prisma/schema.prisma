model Company {
  id                     String                 @id @default(cuid()) @map("id")
  name                   String                 @unique @map("name")
  nameEn                 String?                @map("name_en")
  address                String?
  phone                  String?
  email                  String?
  subscriptionStartDate  DateTime?              @map("subscription_start_date")
  subscriptionEndDate    DateTime?              @map("subscription_end_date")
  isActive               Boolean                @default(true) @map("is_active")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  deletedAt              DateTime?              @map("deleted_at")
  assetStatuses          AssetStatus[]
  assetTypes             AssetType[]
  assets                 Asset[]
  buildings              Building[]
  contractTypes          ContractType[]
  contracts              Contract[]
  drivers                Driver[]
  inventoryItems         InventoryItem[]
  maintenanceFrequencies MaintenanceFrequency[]
  maintenanceGroups      MaintenanceGroup[]
  maintenanceReports     MaintenanceReport[]
  movementTypes          MovementType[]
  reportStatuses         ReportStatus[]
  roles                  Role[]
  users                  User[]
  vehicles               Vehicle[]
  vendors                Vendor[]
  workOrderPriorities    WorkOrderPriority[]
  workOrderStatuses      WorkOrderStatus[]
  workOrders             WorkOrder[]

  @@map("companies")
}

model User {
  id                  String              @id @default(cuid()) @map("id")
  name                String?             @map("name")
  email               String              @unique @map("email")
  emailVerified       DateTime?           @map("email_verified")
  password            String?             @map("password")
  roleId              String?             @map("role_id")
  status              Boolean             @default(false) @map("status")
  activationToken     String?             @unique @map("activation_token")
  activationExpires   DateTime?           @map("activation_expires")
  resetToken          String?             @unique @map("reset_token")
  resetExpires        DateTime?           @map("reset_expires")
  failedLoginAttempts Int                 @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?           @map("locked_until")
  lastLoginAt         DateTime?           @map("last_login_at")
  image               String?
  companyId           String?             @map("company_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  deletedAt           DateTime?           @map("deleted_at")
  branchId            String?             @map("branch_id")
  invitationToken     String?             @unique
  invitationExpires   DateTime?
  firstLogin          Boolean             @default(true)

  // العلاقات
  accidentApprovals   AccidentRequest[]   @relation("AccidentApprovals")
  investigatedReports MaintenanceReport[] @relation("InvestigatedBy")
  oilChangeApprovals  OilChangeRequest[]  @relation("OilChangeApprovals")
  stockMovements      StockMovement[]
  userBuildings       UserBuilding[]
  branch              Building?           @relation(fields: [branchId], references: [id])
  company             Company?            @relation(fields: [companyId], references: [id])
  role                Role?               @relation(fields: [roleId], references: [id])
  workOrders          WorkOrder[]         @relation("AssignedWorkOrders")
  createdWorkOrders   WorkOrder[]         @relation("CreatedWorkOrders")

  @@index([companyId])
  @@index([branchId])
  @@index([deletedAt])
  @@index([companyId, branchId])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid()) @map("id")
  name        String           @unique @map("name")
  label       String?          @map("label")
  description String?          @map("description")
  companyId   String?          @map("company_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  permissions RolePermission[]
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]

  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid()) @map("id")
  name        String           @unique @map("name")
  label       String?          @map("label")
  description String?          @map("description")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AssetStatus {
  id          String   @id @default(cuid()) @map("id")
  name        String   @map("name")
  nameEn      String?  @map("name_en")
  description String?
  color       String?  @default("#64748b") @map("color")
  order       Int      @default(0) @map("order")
  isDefault   Boolean  @default(false) @map("is_default")
  companyId   String?  @map("company_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets      Asset[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("asset_statuses")
}

model AssetType {
  id          String    @id @default(cuid()) @map("id")
  name        String    @map("name")
  nameEn      String?   @map("name_en")
  description String?
  order       Int       @default(0) @map("order")
  isDefault   Boolean   @default(false) @map("is_default")
  companyId   String?   @map("company_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assets      Asset[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("asset_types")
}

model Asset {
  id                 String              @id @default(cuid()) @map("id")
  code               String              @unique @default(cuid()) @map("code")
  name               String              @map("name")
  nameEn             String?             @map("name_en")
  typeId             String?             @map("type_id")
  roomId             String?             @map("room_id")
  purchaseDate       DateTime?           @map("purchase_date")
  warrantyEnd        DateTime?           @map("warranty_end")
  statusId           String?             @map("status_id")
  notes              String?             @map("notes")
  qrCode             String?             @unique @map("qr_code")
  companyId          String              @map("company_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  buildingId         String              @map("building_id")
  building           Building            @relation(fields: [buildingId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  room               Room?               @relation(fields: [roomId], references: [id])
  status             AssetStatus?        @relation(fields: [statusId], references: [id], onDelete: Restrict)
  type               AssetType?          @relation(fields: [typeId], references: [id], onDelete: Restrict)
  maintenanceGroups  MaintenanceAsset[]
  maintenanceReports MaintenanceReport[]
  vehicle            Vehicle?            @relation("VehicleAsset")
  workOrders         WorkOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([typeId])
  @@index([statusId])
  @@index([roomId])
  @@index([buildingId])
  @@index([deletedAt])
  @@index([companyId, buildingId, deletedAt])
  @@index([typeId, statusId])
  @@index([roomId, buildingId])
  @@map("assets")
}

model WorkOrderPriority {
  id          String      @id @default(cuid()) @map("id")
  name        String      @map("name")
  nameEn      String?     @map("name_en")
  color       String?
  description String?
  order       Int         @default(0) @map("order")
  isDefault   Boolean     @default(false) @map("is_default")
  companyId   String?     @map("company_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  company     Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workOrders  WorkOrder[]

  @@index([companyId])
  @@map("work_order_priorities")
