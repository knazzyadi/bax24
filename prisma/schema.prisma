model Vendor {
  id            String    @id @default(cuid()) @map("id")
  name          String    @map("name")
  contactPerson String?   @map("contact_person")
  phone         String?   @map("phone")
  email         String?   @map("email")
  address       String?   @map("address")
  companyId     String?   @map("company_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  company       Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([deletedAt])
  @@map("vendors")
}

model Contract {
  id                 String    @id @default(cuid()) @map("id")
  code               String    @unique @default(cuid()) @map("code")
  title              String    @map("title")
  description        String?   @map("description")
  supplier           String    @map("supplier")
  startDate          DateTime  @map("start_date")
  endDate            DateTime  @map("end_date")
  value              Float?    @map("value")
  status             String    @default("PENDING_REVIEW") @map("status")
  type               String?   @map("type")
  fileUrl            String?   @map("file_url")
  notes              String?   @map("notes")
  companyId          String?   @map("company_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  buildingId         String?   @map("building_id")
  cancellationReason String?   @map("cancellation_reason")
  building           Building? @relation(fields: [buildingId], references: [id])
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
  @@index([buildingId])
  @@index([companyId, buildingId, deletedAt])
  @@index([status, startDate, endDate])
  @@map("contracts")
}

model Driver {
  id               String             @id @default(cuid()) @map("id")
  name             String             @map("name")
  phone            String             @unique @map("phone")
  idNumber         String             @unique @map("id_number")
  isActive         Boolean            @default(true) @map("is_active")
  companyId        String?            @map("company_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  accidentRequests AccidentRequest[]
  company          Company?           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  oilRequests      OilChangeRequest[]
  vehicles         VehicleDriver[]

  @@index([companyId])
  @@index([deletedAt])
  @@map("drivers")
}

model Vehicle {
  id               String             @id @default(cuid()) @map("id")
  code             String             @unique @default(cuid()) @map("code")
  plateNumber      String             @unique @map("plate_number")
  licenseExpiry    DateTime?          @map("license_expiry")
  insuranceExpiry  DateTime?          @map("insurance_expiry")
  lastOilChange    DateTime?          @map("last_oil_change")
  assetId          String             @unique @map("asset_id")
  companyId        String             @map("company_id")
  buildingId       String?            @map("building_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")
  accidentRequests AccidentRequest[]
  oilRequests      OilChangeRequest[]
  drivers          VehicleDriver[]
  asset            Asset              @relation("VehicleAsset", fields: [assetId], references: [id], onDelete: Cascade)
  building         Building?          @relation(fields: [buildingId], references: [id])
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([companyId])
  @@index([deletedAt])
  @@index([companyId, buildingId, deletedAt])
  @@index([code])
  @@map("vehicles")
}

model VehicleDriver {
  id         String   @id @default(cuid()) @map("id")
  vehicleId  String   @map("vehicle_id")
  driverId   String   @map("driver_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  isPrimary  Boolean  @default(false) @map("is_primary")
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, driverId])
  @@index([vehicleId])
  @@index([driverId])
  @@map("vehicle_drivers")
}

model OilChangeRequest {
  id              String    @id @default(cuid()) @map("id")
  vehicleId       String    @map("vehicle_id")
  driverId        String?   @map("driver_id")
  mileage         Int?      @map("mileage")
  invoiceUrl      String?   @map("invoice_url")
  notes           String?   @map("notes")
  status          String    @default("PENDING") @map("status")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  approvedAt      DateTime? @map("approved_at")
  approvedById    String?   @map("approved_by_id")
  rejectionReason String?   @map("rejection_reason")
  deletedAt       DateTime? @map("deleted_at")
  approvedBy      User?     @relation("OilChangeApprovals", fields: [approvedById], references: [id])
  driver          Driver?   @relation(fields: [driverId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([deletedAt])
  @@index([vehicleId, status])
  @@index([status, requestedAt])
  @@map("oil_change_requests")
}

model AccidentRequest {
  id              String    @id @default(cuid()) @map("id")
  vehicleId       String    @map("vehicle_id")
  driverId        String    @map("driver_id")
  accidentDate    DateTime  @map("accident_date")
  location        String    @map("location")
  description     String    @map("description")
  photosUrl       String?   @map("photos_url")
  status          String    @default("PENDING") @map("status")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  approvedAt      DateTime? @map("approved_at")
  approvedById    String?   @map("approved_by_id")
  rejectionReason String?   @map("rejection_reason")
  deletedAt       DateTime? @map("deleted_at")
  mileage         Int?      @map("mileage")
  approvedBy      User?     @relation("AccidentApprovals", fields: [approvedById], references: [id])
  driver          Driver    @relation(fields: [driverId], references: [id])
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([deletedAt])
  @@index([vehicleId, status])
  @@index([status, requestedAt])
  @@map("accident_requests")
}

model UserBuilding {
  id         String   @id @default(cuid()) @map("id")
  userId     String   @map("user_id")
  buildingId String   @map("building_id")
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
  @@map("user_buildings")
}

enum ReportType {
  MAINTENANCE
  INCIDENT
}

enum IncidentSeverity {
  MINOR
  MAJOR
  CRITICAL
}

enum ReportStatusEnum {
  PENDING
  APPROVED
  REJECTED
}
