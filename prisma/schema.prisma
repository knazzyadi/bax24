model MaintenanceGroup {
  id          String               @id @default(cuid()) @map("id")
  description String?              @map("description")
  frequencyId String               @map("frequency_id")
  startDate   DateTime             @map("start_date")
  nextDate    DateTime             @map("next_date")
  endDate     DateTime?            @map("end_date")
  companyId   String               @map("company_id")
  notes       String?              @map("notes")
  buildingId  String?              @map("building_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")
  assets      MaintenanceAsset[]
  building    Building?            @relation(fields: [buildingId], references: [id])
  company     Company              @relation(fields: [companyId], references: [id])
  frequency   MaintenanceFrequency @relation(fields: [frequencyId], references: [id])
  tasks       MaintenanceTask[]

  @@index([buildingId])
  @@index([companyId, buildingId])
  @@index([nextDate])
  @@index([deletedAt])
  @@index([companyId, buildingId, deletedAt])
  @@map("maintenance_groups")
}

model MaintenanceAsset {
  id        String           @id @default(cuid()) @map("id")
